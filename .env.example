# See docs/ENVIRONMENT.md for full reference

# ─── Core ───────────────────────────────────────────────────────────────────
APP_ENV=development
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://kesbyar:kesbyar@localhost:5432/kesbyar?schema=public"

# ─── Web ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# ─── AI service (internal) ──────────────────────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_TOKEN="internal-dev-token-change-in-production"
AI_SERVICE_TIMEOUT_MS=8000
AI_SERVICE_RETRIES=1

# LLM (apps/ai-service — OpenAI-compatible API)
LLM_API_URL="https://api.openai.com/v1"
LLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"
EMBEDDING_MODEL="text-embedding-3-small"

# ─── Operations ─────────────────────────────────────────────
LOG_LEVEL=debug
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=10
STORAGE_PROVIDER=local
ALLOW_SEED=true

# ─── Integration providers (see docs/integrations/) ───────────
BILLING_PROVIDER=manual
NOTIFICATION_PROVIDER=noop
ANALYTICS_PROVIDER=log
# SMS_PROVIDER=kavenegar
# BILLING_ZARINPAL_MERCHANT_ID=

# ─── Invoice online payment (CRM) — Zarinpal / IDPay ─────────
# Prefer per-org keys in Settings (OWNER/ADMIN). Env vars are optional
# platform defaults / single-tenant fallback when an org has no keys set.
# Prefer INVOICE_PAYMENT_PROVIDER; falls back to BILLING_PROVIDER / first configured key.
# INVOICE_PAYMENT_PROVIDER=zarinpal
# PAYMENT_SANDBOX=true
# PAYMENT_ZARINPAL_MERCHANT_ID=
# PAYMENT_IDPAY_API_KEY=
# Legacy aliases also accepted:
# BILLING_ZARINPAL_MERCHANT_ID=
# BILLING_IDPAY_API_KEY=

# ─── SMS (Kavenegar) ─────────────────────────────────────────
# Prefer per-org key in Settings. Env is fallback for single-tenant.
# NOTIFICATION_PROVIDER=kavenegar
# SMS_KAVENEGAR_API_KEY=
# SMS_KAVENEGAR_SENDER=
# KAVENEGAR_API_KEY=   # alias

# ─── Moadian intermediary (optional live path) ───────────────
# Prefer per-org URL+key in Settings. Without org/env intermediary,
# Moadian runs in export/manual-upload mode (honest UI — not tax authority).
# MOADIAN_INTERMEDIARY_URL=
# MOADIAN_INTERMEDIARY_API_KEY=

# Optional dedicated key for encrypting org integration secrets at rest.
# Falls back to derivation from SESSION_SECRET when unset.
# INTEGRATION_SECRETS_KEY=   # 64-char hex or 32-byte base64

# ─── Web Push (in-app notifications + browser alerts) ───────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # optional mirror of public key for client
# VAPID_SUBJECT=mailto:ops@kesbyar.ir

# ─── Destructive ops (scripts only) ─────────────────────────
# CONFIRM_MIGRATE_DEPLOY=true   # required for db:migrate:deploy in production
# CONFIRM_RESTORE=true          # required for db:restore
# ALLOW_RESTORE=true            # additional gate for production restore
# BACKUP_DIR=./backups
# SEED_DEMO=true                # optional: load sample orgs/users (dev/staging only — never production)

# ─── Monitoring (optional) ────────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
