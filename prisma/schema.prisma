generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum IndustryPack {
  GENERAL
  CLINIC
  TRAVEL_AGENCY
  RETAIL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum LeadSource {
  REFERRAL
  INSTAGRAM
  WHATSAPP
  TELEGRAM
  WEBSITE
  WALK_IN
  PHONE
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CHEQUE
  ONLINE
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ActivityType {
  NOTE
  CALL
  MEETING
  MESSAGE
  EMAIL
  STATUS_CHANGE
  PAYMENT
  INVOICE
  TASK
  SYSTEM
}

enum AutomationTrigger {
  INVOICE_OVERDUE
  LEAD_STALE
  TASK_DUE
  PAYMENT_RECEIVED
  CUSTOMER_CREATED
}

enum AutomationAction {
  CREATE_TASK
  SEND_REMINDER
  NOTIFY_USER
  UPDATE_STATUS
}

enum FileEntityType {
  CUSTOMER
  LEAD
  INVOICE
  TASK
  NOTE
  ORGANIZATION
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingRequestStatus {
  INQUIRY
  QUOTED
  CONFIRMED
  DEPARTED
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum PlatformRole {
  USER
  SUPER_ADMIN
}

// ─── Auth & Tenancy ──────────────────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  phone        String?
  passwordHash String
  name         String
  avatarUrl    String?
  platformRole PlatformRole @default(USER)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sessions     Session[]
  memberships  Membership[]
  tasks        Task[]           @relation("TaskAssignee")
  createdTasks Task[]           @relation("TaskCreator")
  reminders    Reminder[]
  notes        Note[]
  activities   ActivityLog[]
  auditEvents  AuditEvent[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Organization {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  industryPack IndustryPack @default(GENERAL)
  phone        String?
  email        String?
  address      String?
  taxId        String?
  currency     String       @default("IRR")
  timezone     String       @default("Asia/Tehran")
  settings     Json         @default("{}")
  extension    Json         @default("{}")
  isDemo       Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  workspaces      Workspace[]
  memberships     Membership[]
  customers       Customer[]
  leads           Lead[]
  products        Product[]
  services        Service[]
  invoices        Invoice[]
  payments        Payment[]
  tasks           Task[]
  reminders       Reminder[]
  notes           Note[]
  activities      ActivityLog[]
  automationRules AutomationRule[]
  fileAttachments FileAttachment[]
  auditEvents     AuditEvent[]
  tags            Tag[]
  pipelineStages  PipelineStage[]
  integrationConfigs IntegrationConfig[]
  practitioners   Practitioner[]
  patientProfiles PatientProfile[]
  appointments    Appointment[]
  visitRecords    VisitRecord[]
  travelerProfiles TravelerProfile[]
  travelBookings  TravelBooking[]
  stockMovements  StockMovement[]
  subscription    Subscription?
  subscriptionEvents SubscriptionEvent[]
}

model Workspace {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(STAFF)
  isActive       Boolean        @default(true)
  joinedAt       DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

/// Singleton platform configuration (id = "platform")
model PlatformSettings {
  id                        String         @id @default("platform")
  defaultSignupMembershipRole MembershipRole @default(OWNER)
  allowSelfRegistration     Boolean        @default(true)
  updatedAt                 DateTime       @updatedAt
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  company        String?
  phone          String?
  email          String?
  nationalId     String?
  address        String?
  city           String?
  notes          String?
  isActive       Boolean  @default(true)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  leads        Lead[]
  invoices     Invoice[]
  payments     Payment[]
  activities   ActivityLog[]
  customerTags CustomerTag[]
  patientProfile PatientProfile?
  travelerProfile TravelerProfile?
  appointments Appointment[]
  travelBookings TravelBooking[]
  visitRecords VisitRecord[]

  @@index([organizationId])
  @@index([organizationId, name])
  @@index([organizationId, deletedAt])
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  phone      String?
  email      String?
  role       String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model PipelineStage {
  id             String @id @default(cuid())
  organizationId String
  name           String
  order          Int    @default(0)
  color          String @default("#6366f1")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@index([organizationId])
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  customerId     String?
  stageId        String?
  title          String
  status         LeadStatus @default(NEW)
  source         LeadSource @default(OTHER)
  value          Decimal?   @db.Decimal(18, 0)
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  description    String?
  nextFollowUpAt DateTime?
  lastContactAt  DateTime?
  wonAt          DateTime?
  lostAt         DateTime?
  lostReason     String?
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  stage        PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  followUps    FollowUpLog[]
  activities   ActivityLog[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
  @@index([nextFollowUpAt])
}

model FollowUpLog {
  id        String   @id @default(cuid())
  leadId    String
  note      String
  channel   String?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Tag {
  id             String @id @default(cuid())
  organizationId String
  name           String
  color          String @default("#64748b")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerTags CustomerTag[]

  @@unique([organizationId, name])
}

model CustomerTag {
  customerId String
  tagId      String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sku            String?
  description    String?
  unitPrice      Decimal  @default(0) @db.Decimal(18, 0)
  unit           String   @default("عدد")
  stockQty       Decimal  @default(0) @db.Decimal(18, 3)
  reorderLevel   Decimal? @db.Decimal(18, 3)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  stockMovements StockMovement[]

  @@index([organizationId])
}

model Service {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  unitPrice      Decimal  @default(0) @db.Decimal(18, 0)
  durationMin    Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@index([organizationId])
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String
  number         String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  subtotal       Decimal       @default(0) @db.Decimal(18, 0)
  discount       Decimal       @default(0) @db.Decimal(18, 0)
  taxAmount      Decimal       @default(0) @db.Decimal(18, 0)
  total          Decimal       @default(0) @db.Decimal(18, 0)
  paidAmount     Decimal       @default(0) @db.Decimal(18, 0)
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items        InvoiceItem[]
  payments     Payment[]
  activities   ActivityLog[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
  @@index([dueDate])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  serviceId   String?
  description String
  quantity    Decimal @default(1) @db.Decimal(18, 3)
  unitPrice   Decimal @default(0) @db.Decimal(18, 0)
  discount    Decimal @default(0) @db.Decimal(18, 0)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal @default(0) @db.Decimal(18, 0)
  sortOrder   Int     @default(0)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String
  invoiceId      String?
  amount         Decimal       @db.Decimal(18, 0)
  method         PaymentMethod @default(CASH)
  status         PaymentStatus @default(COMPLETED)
  reference      String?
  paidAt         DateTime      @default(now())
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  activities   ActivityLog[]

  @@index([organizationId])
  @@index([invoiceId])
}

// ─── Operations ──────────────────────────────────────────────────────────────

model Task {
  id             String       @id @default(cuid())
  organizationId String
  assigneeId     String?
  createdById    String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reminders    Reminder[]
  activities   ActivityLog[]

  @@index([organizationId])
  @@index([assigneeId])
  @@index([dueDate])
}

model Reminder {
  id             String    @id @default(cuid())
  organizationId String
  userId         String?
  taskId         String?
  title          String
  message        String?
  remindAt       DateTime
  isSent         Boolean   @default(false)
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([remindAt])
}

model Note {
  id             String   @id @default(cuid())
  organizationId String
  authorId       String?
  title          String?
  content        String
  entityType     String?
  entityId       String?
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([entityType, entityId])
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  type           ActivityType @default(NOTE)
  title          String
  description    String?
  customerId     String?
  leadId         String?
  invoiceId      String?
  paymentId      String?
  taskId         String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payment      Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([customerId])
}

// ─── Automation & Files ─────────────────────────────────────────────────────

model AutomationRule {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  description    String?
  trigger        AutomationTrigger
  action         AutomationAction
  conditions     Json              @default("{}")
  config         Json              @default("{}")
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model FileAttachment {
  id             String         @id @default(cuid())
  organizationId String
  entityType     FileEntityType
  entityId       String
  fileName       String
  mimeType       String
  sizeBytes      Int
  storagePath    String
  uploadedById   String?
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json     @default("{}")
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdAt])
}

// ─── Integrations (future Iranian providers) ─────────────────────────────────

model IntegrationConfig {
  id             String   @id @default(cuid())
  organizationId String
  provider       String
  label          String
  config         Json     @default("{}")
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
}

// ─── Vertical Packs ──────────────────────────────────────────────────────────

model Practitioner {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  specialty      String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  visitRecords VisitRecord[]

  @@index([organizationId])
}

model PatientProfile {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String   @unique
  fileNumber     String?
  bloodType      String?
  allergies      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Appointment {
  id              String            @id @default(cuid())
  organizationId  String
  customerId      String
  practitionerId  String?
  status          AppointmentStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMin     Int               @default(30)
  reason          String?
  notes           String?
  followUpAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  practitioner Practitioner? @relation(fields: [practitionerId], references: [id], onDelete: SetNull)
  visitRecord  VisitRecord?

  @@index([organizationId])
  @@index([organizationId, scheduledAt])
  @@index([customerId])
}

model VisitRecord {
  id              String    @id @default(cuid())
  organizationId  String
  customerId      String
  appointmentId   String?   @unique
  practitionerId  String?
  visitDate       DateTime  @default(now())
  chiefComplaint  String?
  diagnosis       String?
  treatmentNotes  String?
  followUpAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  practitioner Practitioner? @relation(fields: [practitionerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([customerId])
}

model TravelerProfile {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String   @unique
  passportNo     String?
  nationality    String?  @default("IR")
  preferences    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model TravelBooking {
  id             String               @id @default(cuid())
  organizationId String
  customerId     String
  title          String
  destination    String
  departureDate  DateTime
  returnDate     DateTime?
  travelersCount Int                  @default(1)
  status         BookingRequestStatus @default(INQUIRY)
  quotedAmount   Decimal?             @db.Decimal(18, 0)
  notes          String?
  followUpAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([departureDate])
}

model StockMovement {
  id             String            @id @default(cuid())
  organizationId String
  productId      String
  type           StockMovementType
  quantity       Decimal           @db.Decimal(18, 3)
  reason         String?
  reference      String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productId])
  @@index([organizationId, createdAt])
}

// ─── Billing & Subscriptions ─────────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  planCode           String             @default("FREE")
  status             SubscriptionStatus @default(TRIALING)
  billingPeriod      BillingPeriod      @default(MONTHLY)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  /** Billing provider id: manual, zarinpal, etc. */
  provider           String?
  providerRef        String?
  metadata           Json               @default("{}")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events         SubscriptionEvent[]

  @@index([planCode])
  @@index([status])
}

model SubscriptionEvent {
  id             String   @id @default(cuid())
  organizationId String
  subscriptionId String?
  action         String
  fromPlanCode   String?
  toPlanCode     String?
  actorUserId    String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdAt])
}
