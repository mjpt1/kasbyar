# Staging — inject secrets via platform (Docker secrets / CI vars)
# Never commit real values

APP_ENV=staging
NODE_ENV=production

DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/kesbyar?schema=public

NEXT_PUBLIC_APP_URL=https://staging.example.com
SESSION_SECRET=REPLACE_WITH_32_CHAR_MIN_SECRET

AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_TOKEN=REPLACE_WITH_STRONG_INTERNAL_TOKEN
AI_SERVICE_TIMEOUT_MS=10000
AI_SERVICE_RETRIES=2

LOG_LEVEL=info
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

ALLOW_SEED=false

# Optional sales demo on staging (requires ALLOW_SEED=true for reset)
# DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true

# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
