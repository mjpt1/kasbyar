# Production — inject secrets via platform only
# Never commit real values

APP_ENV=production
NODE_ENV=production

DATABASE_URL=postgresql://USER:PASSWORD@db-host:5432/kesbyar?schema=public&sslmode=require

NEXT_PUBLIC_APP_URL=https://app.example.com
SESSION_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_TOKEN=REPLACE_WITH_STRONG_INTERNAL_TOKEN
AI_SERVICE_TIMEOUT_MS=45000
AI_SERVICE_RETRIES=2

LOG_LEVEL=warn
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

ALLOW_SEED=false

# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
