# See docs/ENVIRONMENT.md

APP_ENV=development
NODE_ENV=development

DATABASE_URL=postgresql://kesbyar:kesbyar@localhost:5432/kesbyar?schema=public

NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string-in-production

AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=internal-dev-token-change-in-production
AI_SERVICE_TIMEOUT_MS=45000
AI_SERVICE_RETRIES=1

LOG_LEVEL=debug
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Seed allowed in local dev
ALLOW_SEED=true

# Optional sample data for internal dev (never enable in production UI)
# SEED_DEMO=true

# Optional monitoring (leave empty locally)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
